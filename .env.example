# Infrastructure base URL
VITE_API_HOST=

# Tenant configuration API endpoint path
VITE_TENANT_CONFIG_PATH=

# Application environment (development, staging, production)
VITE_APP_ENV=

# Development-only variable to override domain resolution (forces a specific tenant)
VITE_DEV_OVERRIDE_DOMAIN=

# Toggle to serve local mock data instead of hitting the live API (development convenience)
# Set to "true" to use src/mocks/data.ts; leave empty / "false" in production.
VITE_USE_MOCKS=
